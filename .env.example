# X-Ray_LLM environment variables (copy to .env if needed)
# All vars are optional — sensible defaults live in configs/config.yaml

# Path to the main YAML config
CONFIG_PATH=configs/config.yaml

# CORS origins (comma-separated). Leave unset to use config.yaml
# WEB_CORS_ORIGINS=http://localhost:3000,http://localhost:7860

# Max upload size in MB (overrides config.yaml web.backend.max_upload_mb)
# MAX_UPLOAD_MB=10
